{
  "privacy": {
    "icon-spacing": 10,
    "icon-size": 14,
    "transition-duration": 50,
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": false,
    "start-activated": true,
    "format-icons": {
      "activated": "",
      "deactivated": "",
    },
  },
  "memory": {
    "interval": 30,
    "format": "  {used}GiB",
    "tooltip": false,
  },
}
